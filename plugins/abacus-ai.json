{
  "$schema": "https://raw.githubusercontent.com/invoiceradar/plugins/main/schema.json",
  "id": "abacus-ai",
  "name": "Abacus.AI",
  "description": "Abacus.AI ChatLLM",
  "homepage": "https://abacus.ai/chat_llm-ent",
  "configSchema": {},
  "checkAuth": [
    {
      "action": "navigate",
      "url": "https://apps.abacus.ai/chatllm/admin/profile",
      "waitForNetworkIdle": true
    },
    {
      "action": "checkURL",
      "url": "https://apps.abacus.ai/chatllm/admin/profile"
    }
  ],
  "startAuth": [
    {
      "action": "navigate",
      "url": "https://apps.abacus.ai/chatllm/admin/profile"
    },
    {
      "action": "waitForURL",
      "url": "https://apps.abacus.ai/chatllm/**",
      "timeout": 120000
    }
  ],
  "getDocuments": [
    {
      "action": "navigate",
      "url": "https://apps.abacus.ai/chatllm/admin/billing/"
    },
    {
      "action": "extractAll",
      "script": "fetch('https://abacus.ai/api/v0/_listInvoices', { method: 'POST', headers: { 'content-type': 'application/x-www-form-urlencoded', 'x-abacus-org-host': 'apps' }, credentials: 'include' }).then(r => r.json()).then(r => r.result.filter(i => i.lifecycle === 'PAID').map(i => ({ id: i.invoiceId, date: i.createdAt.slice(0, 10), total: (i.total / 100).toFixed(2) + ' USD' })))",
      "variable": "invoice",
      "forEach": [
        {
          "action": "downloadPdf",
          "url": "https://abacus.ai/api/v0/_downloadChatllmTeamsInvoicePdf?invoiceId={{invoice.id}}",
          "document": {
            "type": "invoice",
            "id": "{{invoice.id}}",
            "date": "{{invoice.date}}",
            "total": "{{invoice.total}}"
          }
        }
      ]
    }
  ]
}
